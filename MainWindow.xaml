<Window x:Class="DevPath.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DevPath"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <SolidColorBrush x:Key="AppPanelBackgroundBrush" Color="#F3F4F8"/>
    </Window.Resources>
    
    <Grid Background="{StaticResource AppPanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <Border Background="#E8EEF5"
            CornerRadius="10"
            Grid.Row="1"
            Grid.Column="0"
            Margin="20"
            BorderBrush="Gray"
            BorderThickness="1">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#E8EEF5"
                    CornerRadius="10"
                    Grid.Row="0"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock  
                            Text="Courses"
                            FontSize="24"
                            FontWeight="Bold"
                            Margin="0,0,0,10"/>

                        <ListBox
                            Background="{StaticResource AppPanelBackgroundBrush}"
                            x:Name="CoursesListBox"
                            Grid.Row="1"
                            FontSize="26"
                            SelectionChanged="CoursesListBox_SelectionChanged">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,4,0,4">
                                        <TextBlock
                                            Text="{Binding DisplayText}"
                                            FontSize="22"
                                            Margin="0,0,0,4"/>
                                        <ProgressBar
                                            Height="8"
                                            Minimum="0"
                                            Maximum="100"
                                            Value="{Binding Progress}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>

                        </ListBox>
                    </Grid>
                </Border>

                    
                    
                <Border Background="#E8EEF5"
                    CornerRadius="10"
                    Grid.Row="2"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock 
                            Text="Lessons"
                            FontSize="24"
                            FontWeight="Bold"
                            Margin="0,0,0,10"/>

                        <ListBox
                            Background="{StaticResource AppPanelBackgroundBrush}"
                            x:Name="LessonsListBox"
                            Grid.Row="1"
                            FontSize="22"
                            HorizontalContentAlignment="Stretch"
                            SelectionChanged="LessonsListBox_SelectionChanged">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{Binding Title}"/>

                                        <TextBlock Grid.Column="1"
                                           Text="{Binding Status}"
                                           HorizontalAlignment="Right"
                                           Margin="20,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock 
                            x:Name="LessonsDescriptionTextBlock"
                            Grid.Row="2"
                            Margin="0,10,0,0"
                            FontSize="18"
                            TextWrapping="Wrap"
                            VerticalAlignment="Top"/>
                    </Grid>
                </Border>

                <Border Background="#E8EEF5"
                    CornerRadius="10"
                    Grid.Row="4"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Topic"
                            FontSize="24"
                            FontWeight="Bold"
                            Margin="0,0,0,10"/>

                        <ListBox 
                            Background="{StaticResource AppPanelBackgroundBrush}"
                            x:Name="TopicsListBox"
                            Grid.Row="1"
                            FontSize="22"
                            DisplayMemberPath="DisplayText"
                            SelectionChanged="TopicsListBox_SelectionChanged"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>


        <Border Background="#E8EEF5"
            CornerRadius="10"
            Grid.Row="1"
            Grid.Column="1"
            Grid.ColumnSpan="2"
            Margin="20"
            BorderBrush="Gray"
            BorderThickness="1">

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock
                    Text="Examples / Practice Tasks"
                    FontSize="24"
                    FontWeight="Bold"
                    Margin="0,0,0,10"/>
               
                <Border
                    Grid.Row="1"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    Padding="20"
                    Margin="0,20,0,0">


                    <ScrollViewer
                        x:Name="ExamplesScrollViewer"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">

                        <Grid Margin="30,16,30,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="1"
                                Width="{Binding ActualWidth, ElementName=ExamplesScrollViewer}"
                                MaxWidth="1500"
                                Padding="0">
                                <StackPanel
                                    x:Name="ExamplesPanel"/>
                            </Border>
                        </Grid>
                    </ScrollViewer>

                </Border>

            </Grid>



        </Border>

    </Grid>
</Window>
